# Copy to backend/.env (gitignored) before running
#
# Only HF_TOKEN is required if you have already run `hf auth login` (the
# huggingface_hub Python client reads ~/.cache/huggingface/token by default).
# Set explicitly here if you want a different token, or for CI/Docker.

# ─── Hugging Face Inference Providers ───────────────────────────────────
# Token MUST have "Make calls to Inference Providers" permission.
# Get one at: https://huggingface.co/settings/tokens/new?tokenType=fineGrained
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_ORG=EHubBarcelona

# Optional model overrides (defaults defined in backend/app/services/llm.py)
# LLM_FAST_MODEL=meta-llama/Llama-3.3-70B-Instruct
# LLM_FAST_PROVIDER=groq
# LLM_DEEP_MODEL=moonshotai/Kimi-K2-Instruct
# LLM_DEEP_PROVIDER=novita
# LLM_FALLBACK_MODEL=Qwen/Qwen2.5-72B-Instruct

# ─── Deterministic anonymization ────────────────────────────────────────
# Same value across machines so anon labels match in commits and demo
PYTHONHASHSEED=42

# ─── MongoDB (live state during dev) ────────────────────────────────────
# Local default works if you `brew services start mongodb-community`
MONGO_URI=mongodb://localhost:27017
MONGO_DB=marketpulse

# ─── External APIs (all free, no key needed for the defaults) ───────────
# Open-Meteo: no key. ONS: no key. Google Trends via pytrends: no key.
# FRED is optional and DOES need a key if you enable it:
# FRED_API_KEY=

# ─── Snapshot mode (offline demo safety net) ────────────────────────────
# When set, the FE loads pre-baked JSON instead of calling the FastAPI
# backend. Used by the ⌘+. shortcut on the FE.
# SNAPSHOT_MODE=0

# ─── Dev/debug ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RELOAD=1
